": 0.197}, {"word": "maar", "start": 45.145, "end": 45.305, "score": 0.686}, {"word": "met", "start": 45.345, "end": 45.525, "score": 0.861}, {"word": "z'n", "start": 45.626, "end": 45.806, "score": 0.542}, {"word": "allen", "start": 45.826, "end": 46.347, "score": 0.792}, {"word": "in", "start": 46.667, "end": 46.707, "score": 0.026}, {"word": "je", "start": 46.727, "end": 46.767, "score": 0.002}, {"word": "stoel.", "start": 46.787, "end": 52.116, "score": 0.706}]}, {"start": 52.136, "end": 53.258, "text": "Komt u aan!", "words": [{"word": "Komt", "start": 52.136, "end": 52.577, "score": 0.845}, {"word": "u", "start": 52.597, "end": 53.158, "score": 0.964}, {"word": "aan!", "start": 53.178, "end": 53.258, "score": 0.0}]}, {"start": 58.857, "end": 61.638, "text": " Ben er toch in die stoel?", "words": [{"word": "Ben", "start": 58.857, "end": 59.038, "score": 0.498}, {"word": "er", "start": 59.079, "end": 59.159, "score": 0.742}, {"word": "toch", "start": 59.179, "end": 59.3, "score": 0.669}, {"word": "in", "start": 59.361, "end": 59.482, "score": 0.8}, {"word": "die", "start": 59.522, "end": 59.663, "score": 0.802}, {"word": "stoel?", "start": 59.683, "end": 61.638, "score": 0.767}]}, {"start": 61.658, "end": 63.411, "text": "Let op!", "words": [{"word": "Let", "start": 61.658, "end": 61.88, "score": 0.784}, {"word": "op!", "start": 61.9, "end": 63.411, "score": 0.897}]}, {"start": 63.492, "end": 64.378, "text": "Naar nu!", "words": [{"word": "Naar", "start": 63.492, "end": 64.298, "score": 0.468}, {"word": "nu!", "start": 64.318, "end": 64.378, "score": 0.0}]}], "word_segments": [{"word": "Ben", "start": 0.031, "end": 0.471, "score": 0.769}, {"word": "je", "start": 0.491, "end": 0.692, "score": 0.944}, {"word": "jong?", "start": 0.752, "end": 1.192, "score": 0.577}, {"word": "Ben", "start": 1.292, "end": 1.452, "score": 0.629}, {"word": "je", "start": 1.492, "end": 2.113, "score": 0.435}, {"word": "oud?", "start": 2.133, "end": 2.213, "score": 0.467}, {"word": "Ben