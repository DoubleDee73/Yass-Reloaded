{"segments": [{"start": 0.031, "end": 1.192, "text": " Ben je jong?", "words": [{"word": "Ben", "start": 0.031, "end": 0.471, "score": 0.769}, {"word": "je", "start": 0.491, "end": 0.692, "score": 0.944}, {"word": "jong?", "start": 0.752, "end": 1.192, "score": 0.577}]}, {"start": 1.292, "end": 2.213, "text": "Ben je oud?", "words": [{"word": "Ben", "start": 1.292, "end": 1.452, "score": 0.629}, {"word": "je", "start": 1.492, "end": 2.113, "score": 0.435}, {"word": "oud?", "start": 2.133, "end": 2.213, "score": 0.467}]}, {"start": 2.273, "end": 4.235, "text": "Ben je klein of getrouwd?", "words": [{"word": "Ben", "start": 2.273, "end": 2.453, "score": 0.946}, {"word": "je", "start": 2.493, "end": 2.854, "score": 0.879}, {"word": "klein", "start": 2.874, "end": 3.194, "score": 0.436}, {"word": "of", "start": 3.274, "end": 3.494, "score": 0.413}, {"word": "getrouwd?", "start": 3.514, "end": 4.235, "score": 0.376}]}, {"start": 4.315, "end": 6.277, "text": "Zit dat bankie wat sloef?", "words": [{"word": "Zit", "start": 4.315, "end": 4.455, "score": 0.489}, {"word": "dat", "start": 4.495, "end": 5.296, "score": 0.541}, {"word": "bankie", "start": 5.316, "end": 5.436, "score": 0.037}, {"word": "wat", "start": 5.456, "end": 5.696, "score": 0.233}, {"word": "sloef?", "start": 5.716, "end": 6.277, "score": 0.608}]}, {"start": 6.297, "end": 8.219, "text": "Leg je voet op de proef.", "words": [{"word": "Leg", "start": 6.297, "end": 6.497, "score": 0.592}, {"word": "je", "start": 6.537, "end": 6.737, "score": 0.885}, {"word": "voet", "start": 6.757, "end": 7.218, "score": 0.883}, {"word": "op", "start": 7.298, "end": 7.598, "score": 0.392}, {"word": "de", "start": 7.618, "end": 7.658, "score": 0.001}, {"word": "proef.", "start": 7.678, "end": 8.219, "score": 0.769}]}, {"start": 8.259, "end": 10.24, "text": "Doe de deur maar op slot.", "words": [{"word": "Doe", "start": 8.259, "end": 8.499, "score": 0.688}, {"word": "de", "start": 8.539, "end": 8.739, "score": 0.862}, {"word": "