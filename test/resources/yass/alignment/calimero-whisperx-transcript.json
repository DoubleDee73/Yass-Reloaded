{"word": "de", "start": 23.264, "end": 23.304, "score": 0.026}, {"word": "gekste", "start": 23.324, "end": 23.444, "score": 0.013}, {"word": "avonturen.", "start": 23.464, "end": 23.665, "score": 0.004}]}, {"start": 23.685, "end": 28.792, "text": "Krijgt het soms behoorlijk te verduren.", "words": [{"word": "Krijgt", "start": 23.685, "end": 23.805, "score": 0.009}, {"word": "het", "start": 23.825, "end": 24.065, "score": 0.335}, {"word": "soms", "start": 24.085, "end": 24.165, "score": 0.004}, {"word": "behoorlijk", "start": 24.185, "end": 24.887, "score": 0.317}, {"word": "te", "start": 24.907, "end": 25.267, "score": 0.729}, {"word": "verduren.", "start": 25.287, "end": 28.792, "score": 0.152}]}, {"start": 28.812, "end": 29.473, "text": "Kijken jullie mee naar Kali Mero.", "words": [{"word": "Kijken", "start": 28.812, "end": 28.933, "score": 0.0}, {"word": "jullie", "start": 28.953, "end": 29.073, "score": 0.0}, {"word": "mee", "start": 29.093, "end": 29.153, "score": 0.0}, {"word": "naar", "start": 29.173, "end": 29.253, "score": 0.005}, {"word": "Kali", "start": 29.273, "end": 29.353, "score": 0.002}, {"word": "Mero.", "start": 29.373, "end": 29.473, "score": 0.044}]}, {"start": 29.493, "end": 33.479, "text": "Beleef het mee.", "words": [{"word": "Beleef", "start": 29.493, "end": 29.854, "score": 0.434}, {"word": "het", "start": 29.874, "end": 30.154, "score": 0.702}, {"word": "mee.", "start": 30.194, "end": 33.479, "score": 0.819}]}, {"start": 33.499, "end": 37.726, "text": "Soms is hij wel eens onhandig en denkt dan niet naar buimand.", "words": [{"word": "Soms", "start": 33.499, "end": 33.58, "score": 0.122}, {"word": "is", "start": 33.6, "end": 33.64, "score": 0.004}, {"word": "hij", "start": 33.66, "end": 34.0, "score": 0.38}, {"word": "wel", "start": 34.02, "end": 34.381, "score": 0.385}, {"word": "eens", "start": 34.401, "end": 36.905, "score": 0.443}, {"word": "onhandig", "start": 36.925, "end": 37.085, "score": 0.0}, {"word": "en", "start": 37.105, "end": 37.145, "score": 0.0}, {"word": "denkt", "start": 37.165, "end": 37.265, "score": 0.0}, {"word": "dan", "start": 37.285, "end": 37.345, "score": 0.0}, {"word": "niet", "start": 37.365, "end": 37.445, "score": 0.0}, {"word": "naar", "start": 37.465, "end": 37.545, "score": 0.0}, {"word": "buimand.", "start": 37.566, "end": 37.726, "score": 0.0}]}, {"start": 37.746, "end": 37.906, "text": "Hij doet", "words": [{"word": "Hij", "start": 37.746, "end": 37.806, "score": 0.0}, {"word": "doet", "start": 37.826, "end": 37.906, "score": 0.0}]}, {"start": 38.978, "end": 57.018, "text": " Lees niet ongelust, want wat er ook gebeurt, het komt altijd.", "words": [{"word": "Lees", "start": 38.978, "end": 39.238, "score": 0.493}, {"word": "niet", "start": 39.278, "end": 40.139, "score": 0.683}, {"word": "ongelust,", "start": 40.159, "end": 41.22, "score": 0.41}, {"word": "want", "start": 41.241, "end": 50.13, "score": 0.555}, {"word": "wat", "start": 50.15, "end": 51.071, "score": 0.36}, {"word": "er", "start": 51.091, "end": 51.532, "score": 0.404}, {"word": "ook", "start": 51.552, "end": 51.612, "score": 0.002}, {"word": "gebeurt,", "start": 51.632, "end": 53.654, "score": 0.299}, {"word": "het", "start": 53.674, "end": 56.377, "score": 0.444}, {"word": "komt", "start": 56.397, "end": 56.477, "score": 0.0}, {"word": "altijd.", "start": 56.497, "end": 57.018, "score": 0.302}]}, {"start": 57.038, "end": 57.218, "text": "Ben goed.", "words": [{"word": "Ben", "start": 57.038, "end": 57.098, "score": 0.001}, {"word": "goed.", "start": 57.118, "end": 57.218, "score": 0.074}]}, {"start": 57.238, "end": 57.819, "text": "Kom allemaal.", "words": [{"word": "Kom", "start": 57.238, "end": 57.298, "score": 0.0}, {"word": "allemaal.", "start": 57.318, "end": 57.819, "score": 0.344}]}, {"start": 57.839, "end": 58.92, "text": "Weer een verhaal.", "words": [{"word": "Weer", "start": 57.839, "end": 58.66, "score": 0.532}, {"word": "een", "start": 58.68, "end": 58.74, "score": 0.0}, {"word": "verhaal.", "start": 58.76, "end": 58.92, "score": 0.003}]}, {"start": 58.94, "end": 61.823, "text": "Want Cali-Meroe gaat op patto-ladier.", "words": [{"word": "Want", "start": 58.94, "end": 59.02, "score": 0.067}, {"word": "Cali-Meroe", "start": 59.04, "end": 60.722, "score": 0.234}, {"word": "gaat", "start": 60.742, "end": 60.822, "score": 0.059}, {"word": "op", "start": 60.842, "end": 60.882, "score": 0.012}, {"word": "patto-ladier.", "start": 60.902, "end": 61.823, "score": 0.106}]}, {"start": 61.843, "end": 62.204, "text": "Beleef het mee.", "words": [{"word": "Beleef", "start": 61.843, "end": 61.963, "score": 0.018}, {"word": "het", "start": 61.983, "end": 62.104, "score": 0.472}, {"word": "mee.", "start": 62.124, "end": 62.204, "score": 0.003}]}, {"start": 62.224, "end": 63.425, "text": "Ben je zo gevaardig niet en altijd aardig?", "words": [{"word": "Ben", "start": 62.224, "end": 62.284, "score": 0.001}, {"word": "je", "start": 62.304, "end": 62.344, "score": 0.001}, {"word": "zo", "start": 62.364, "end": 62.404, "score": 0.0}, {"word": "gevaardig", "start": 62.424, "end": 62.965, "score": 0.115}, {"word": "niet", "start": 62.985, "end": 63.065, "score": 0.062}, {"word": "en", "start": 63.085, "end": 63.125, "score": 0.0}, {"word": "altijd", "start": 63.145, "end": 63.265, "score": 0.005}, {"word": "aardig?", "start": 63.285, "end": 63.425, "score": 0.008}]}, {"start": 63.445, "end": 64.106, "text": "Ben je ingevaard?", "words": [{"word": "Ben", "start": 63.445, "end": 63.505, "score": 0.011}, {"word": "je", "start": 63.525, "end": 63.565, "score": 0.126}, {"word": "ingevaard?", "start": 63.585, "end": 64.106, "score": 0.221}]}, {"start": 64.126, "end": 64.887, "text": "Dan staat-ie voor je klaar.", "words": [{"word": "Dan", "start": 64.126, "end": 64.186, "score": 0.0}, {"word": "staat-ie", "start": 64.206, "end": 64.586, "score": 0.163}, {"word": "voor", "start": 64.606, "end": 64.686, "score": 0.014}, {"word": "je", "start": 64.706, "end": 64.747, "score": 0.002}, {"word": "klaar.", "start": 64.767, "end": 64.887, "score": 0.002}]}, {"start": 64.907, "end": 65.407, "text": "Net het witte eierdoppie.", "words": [{"word": "Net", "start": 64.907, "end": 64.967, "score": 0.009}, {"word": "het", "start": 64.987, "end": 65.047, "score": 0.004}, {"word": "witte", "start": 65.067, "end": 65.167, "score": 0.017}, {"word": "eierdoppie.", "start": 65.187, "end": 65.407, "score": 0.006}]}, {"start": 65.427, "end": 65.788, "text": "Otse lieve koppie.", "words": [{"word": "Otse", "start": 65.427, "end": 65.507, "score": 0.002}, {"word": "lieve", "start": 65.527, "end": 65.628, "score": 0.0}, {"word": "koppie.", "start": 65.648, "end": 65.788, "score": 0.003}]}, {"start": 65.808, "end": 66.869, "text": "Kijk maar mee.", "words": [{"word": "Kijk", "start": 65.808, "end": 65.888, "score": 0.002}, {"word": "maar", "start": 65.908, "end": 65.988, "score": 0.0}, {"word": "mee.", "start": 66.008, "end": 66.869, "score": 0.353}]}, {"start": 66.889, "end": 67.89, "text": "Beleef het mee!", "words": [{"word": "Beleef", "start": 66.889, "end": 67.71, "score": 0.235}, {"word": "het", "start": 67.73, "end": 67.79, "score": 0.0}, {"word": "mee!", "start": 67.81, "end": 67.89, "score": 0.0}]}], "word_segments": [{"word": "Kijken", "start": 8.482, "end": 8.863, "score": 0.485}, {"word": "jullie", "start": 8.883, "end": 10.104, "score": 0.65}, {"word": "mee", "start": 10.144, "end": 10.966, "score": 0.815}, {"word": "naar", "start": 10.986, "end": 11.066, "score": 0.002}, {"word": "Kali", "start": 11.086, "end": 11.446, "score": 0.279}, {"word": "Mero", "start": 11.466, "end": 11.547, "score": 0.012}, {"word": "en", "start": 11.567, "end": 11.607, "score": 0.006}, {"word": "zijn", "start": 11.627, "end": 11.747, "score": 0.295}, {"word": "vriendjes", "start": 11.767, "end": 12.188, "score": 0.351}, {"word": "op", "start": 12.208, "end": 12.468, "score": 0.584}, {"word": "tv.", "start": 12.508, "end": 14.291, "score": 0.863}, {"word": "Zitten", "sta